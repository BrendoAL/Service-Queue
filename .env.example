SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/queue_db
SPRING_DATASOURCE_USERNAME=queue_user
SPRING_DATASOURCE_PASSWORD=queue_pass
JWT_EXPIRATION_MS=28800000

# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-base64-secret-min-256-bits

# Initial admin bootstrap. The user is created only if it does not exist.
QUEUE_ADMIN_USERNAME=admin
QUEUE_ADMIN_PASSWORD=replace-with-strong-password

# Comma-separated browser origins allowed to call the REST API.
QUEUE_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:4200

# Comma-separated WebSocket origins allowed to connect to /ws.
QUEUE_WEBSOCKET_ALLOWED_ORIGIN_PATTERNS=http://localhost:4200
